  --accent-light: #4fc3f7;
  --accent-glow: rgba(79, 195, 247, 0.75);
  --accent-glow-strong: rgba(79, 195, 247, 0.9);

  /* Backgrounds & Surfaces */
  --background: #05050a;
  --glass-bg: rgba(20, 20, 35, 0.68);     /* Main card background */
  --glass-border: rgba(255, 255, 255, 0.22);
  --control-bg: rgba(28, 28, 44, 0.85);
  --slider-bg: rgba(148, 163, 184, 0.25);

  /* Shadows */
  --shadow-dark: #080808;
  --shadow-light: #404040;

  /* Text */
  --text-primary: #e0e0e0;
  --text-secondary: #bae6fd;
  --text-muted: #94a3b8;
  --text-on-accent: #0f172a;

  /* Toggles */
  --toggle-bg-off: rgba(28, 28, 44, 0.85);
  --toggle-handle: rgba(241, 245, 249, 0.98);
  --toggle-checked-color: #0ea5e9;
  --toggle-knob-border: #e2e8f0;

  /* Bug Mode (Red special mode) */
  --bug-color: #e11d48;
  --bug-fill-glow: rgba(225, 29, 72, 0.9);

  /* Toast */
  --toast-success: rgb(16, 185, 129);
  --toast-error: rgb(244, 63, 94);
  --toast-warning: rgb(251, 191, 36);
  --toast-info: rgb(56, 189, 248);
}

